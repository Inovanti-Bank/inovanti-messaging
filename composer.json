{
  "name": "inovanti-bank/messaging",
  "description": "Componente para integração com serviços de mensageria com APIs externas como Twilio, SendGrid, AWS SES, etc.",
  "type": "library",
  "require": {
    "php": "^8.2",
    "laravel/framework": "^11.0|^10.0",
    "sendgrid/sendgrid": "^8.1",
    "twilio/sdk": "^8.3",
    "vlucas/phpdotenv": "^5.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5",
    "mockery/mockery": "^2.0",
    "laravel/pint": "^1.19"
  },
  "extra": {
    "laravel": {
      "providers": [
        "InovantiBank\\Messaging\\Providers\\MessagingServiceProvider"
      ],
      "aliases": {}
    }
  },
  "autoload": {
    "psr-4": {
      "InovantiBank\\Messaging\\": "src/Messaging/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "unit": "vendor/bin/phpunit --testsuite=Unit",
    "pint": "vendor/bin/pint"
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "license": "MIT",
  "keywords": [
    "laravel",
    "messaging",
    "Twilio",
    "AWS SES",
    "SendGrid",
    "phpunit",
    "eloquent"
  ],
  "authors": [
    {
      "name": "inovanti Ip",
      "email": "dev@inovanti.com.br"
    }
  ]
}
